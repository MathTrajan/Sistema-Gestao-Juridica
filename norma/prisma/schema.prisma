generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ESCRITÓRIO (multiempresa / SaaS) ────────────────────────────────────────
model Escritorio {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String?  @unique
  email     String?
  telefone  String?
  endereco  String?
  oab       String?
  plano     Plano    @default(BASICO)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios   Usuario[]
  clientes   Cliente[]
  processos  Processo[]
  tarefas    Tarefa[]
  leads      Lead[]
  financeiro Lancamento[]
  advogadosMonitorados AdvogadoMonitorado[]
  notificacoes         Notificacao[]

  @@map("escritorios")
}

enum Plano {
  BASICO
  PROFISSIONAL
  ENTERPRISE
}

// ─── USUÁRIOS ─────────────────────────────────────────────────────────────────
model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String
  senha     String
  perfil    Perfil   @default(COLABORADOR)
  area      Area?
  oab       String?
  telefone  String?
  ativo      Boolean  @default(true)
  permissoes String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  escritorioId String
  escritorio   Escritorio @relation(fields: [escritorioId], references: [id])

  tarefasResponsavel   Tarefa[]   @relation("TarefaResponsavel")
  tarefasCriadas       Tarefa[]   @relation("TarefaCriador")
  processosResponsavel Processo[] @relation("ProcessoResponsavel")
  atendimentos         Atendimento[]
  comentarios          Comentario[]
  advogadosMonitorados AdvogadoMonitorado[]
  notificacoes         Notificacao[]

  @@unique([email, escritorioId])
  @@index([escritorioId])
  @@index([email])
  @@map("usuarios")
}

enum Perfil {
  GESTOR_GERAL
  GERENTE
  COLABORADOR
}

enum Area {
  COMERCIAL
  CONTROLADORIA
  JURIDICO
  FINANCEIRO
  MARKETING
}

// ─── CLIENTES ─────────────────────────────────────────────────────────────────
model Cliente {
  id             String        @id @default(cuid())
  tipo           TipoCliente   @default(PESSOA_FISICA)
  nomeCompleto   String
  cpf            String?
  rg             String?
  dataNascimento DateTime?
  razaoSocial    String?
  cnpj           String?
  email          String?
  telefone       String?
  whatsapp       String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  areaJuridica   AreaJuridica?
  origemCliente  OrigemCliente?
  status         StatusCliente @default(ATIVO)
  observacoes    String?
  valorContrato  Decimal?      @db.Decimal(10, 2)
  dataContrato   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  escritorioId String
  escritorio   Escritorio @relation(fields: [escritorioId], references: [id])

  processos    Processo[]
  documentos   Documento[]
  atendimentos Atendimento[]
  lancamentos  Lancamento[]
  lead         Lead?

  @@index([escritorioId])
  @@index([escritorioId, status])
  @@map("clientes")
}

enum TipoCliente {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum AreaJuridica {
  TRABALHISTA
  CIVIL
  TRIBUTARIO
  PREVIDENCIARIO
  CRIMINAL
  FAMILIA
  EMPRESARIAL
  CONSUMIDOR
  AMBIENTAL
  OUTRO
}

enum OrigemCliente {
  INDICACAO
  SITE
  INSTAGRAM
  GOOGLE
  WHATSAPP
  OUTRO
}

enum StatusCliente {
  ATIVO
  INATIVO
  PROSPECTO
  DOCUMENTACAO_PENDENTE
}

// ─── PROCESSOS ────────────────────────────────────────────────────────────────
model Processo {
  id               String         @id @default(cuid())
  numero           String?
  tribunal         String?
  vara             String?
  comarca          String?
  tipoAcao         String?
  areaJuridica     AreaJuridica?
  tipo             TipoProcesso   @default(JUDICIAL)
  fase             FaseProcesso   @default(CONHECIMENTO)
  status           StatusProcesso @default(EM_ANDAMENTO)
  dataDistribuicao DateTime?
  valorCausa       Decimal?       @db.Decimal(10, 2)
  observacoes      String?
  lastSyncAt       DateTime?      // última sincronização com o DataJud

  // ─── Dados oficiais (DataJud / CNJ) ─────────────────────────────────────────
  grau                         String?   // "G1" | "G2" | "GS"
  sistema                      String?   // ex: "PJe", "eproc", "SAJ"
  formato                      String?   // ex: "Eletrônico", "Físico"
  nivelSigilo                  Int?      // 0 = público
  classeCodigo                 Int?
  classeNome                   String?   // ex: "Procedimento Comum Cível"
  assuntos                     Json?     // [{ codigo, nome }, ...]
  orgaoJulgador                String?   // ex: "1ª Vara Cível de Goiânia"
  orgaoJulgadorCodigo          String?
  municipioIbge                Int?
  dataAjuizamentoDataJud       DateTime?
  dataUltimaAtualizacaoDataJud DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  clienteId     String
  cliente       Cliente    @relation(fields: [clienteId], references: [id])
  escritorioId  String
  escritorio    Escritorio @relation(fields: [escritorioId], references: [id])
  responsavelId String?
  responsavel   Usuario?   @relation("ProcessoResponsavel", fields: [responsavelId], references: [id])

  tarefas       Tarefa[]
  documentos    Documento[]
  prazos        Prazo[]
  movimentacoes Movimentacao[]
  andamentos    Andamento[]

  @@index([escritorioId])
  @@index([escritorioId, status])
  @@index([clienteId])
  @@map("processos")
}

enum TipoProcesso {
  JUDICIAL
  ADMINISTRATIVO
}

enum FaseProcesso {
  CONHECIMENTO
  RECURSAL
  EXECUCAO
  ENCERRADO
}

enum StatusProcesso {
  EM_ANDAMENTO
  AGUARDANDO_PECA
  AGUARDANDO_CLIENTE
  SUSPENSO
  ENCERRADO_PROCEDENTE
  ENCERRADO_IMPROCEDENTE
  ARQUIVADO
}

// ─── TAREFAS ──────────────────────────────────────────────────────────────────
model Tarefa {
  id             String       @id @default(cuid())
  titulo         String
  descricao      String?
  status         StatusTarefa @default(A_FAZER)
  prioridade     Prioridade   @default(NORMAL)
  dataVencimento DateTime?
  dataConclusao  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  escritorioId  String
  escritorio    Escritorio @relation(fields: [escritorioId], references: [id])
  responsavelId String?
  responsavel   Usuario?   @relation("TarefaResponsavel", fields: [responsavelId], references: [id])
  criadorId     String?
  criador       Usuario?   @relation("TarefaCriador", fields: [criadorId], references: [id])
  processoId    String?
  processo      Processo?  @relation(fields: [processoId], references: [id])
  prazoId       String?
  prazo         Prazo?     @relation(fields: [prazoId], references: [id])

  comentarios Comentario[]

  @@index([escritorioId])
  @@index([escritorioId, status])
  @@index([dataVencimento])
  @@index([prazoId])
  @@map("tarefas")
}

enum StatusTarefa {
  A_FAZER
  EM_ANDAMENTO
  AGUARDANDO_REVISAO
  CONCLUIDO
  CANCELADO
}

enum Prioridade {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

// ─── PRAZOS ───────────────────────────────────────────────────────────────────
model Prazo {
  id          String      @id @default(cuid())
  titulo      String
  tipo        TipoPrazo
  dataInicio  DateTime
  dataFinal   DateTime
  diasUteis   Int?
  status      StatusPrazo @default(ABERTO)
  observacoes String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  processoId String
  processo   Processo @relation(fields: [processoId], references: [id])
  tarefas    Tarefa[]

  @@index([processoId])
  @@index([dataFinal, status])
  @@map("prazos")
}

enum TipoPrazo {
  RECURSO
  CONTESTACAO
  MANIFESTACAO
  REPLICA
  APELACAO
  CONTRARRAZOES
  EMBARGOS
  OUTRO
}

enum StatusPrazo {
  ABERTO
  CUMPRIDO
  PERDIDO
  SUSPENSO
}

// ─── LEADS / CRM ──────────────────────────────────────────────────────────────
model Lead {
  id            String        @id @default(cuid())
  nome          String
  email         String?
  telefone      String?
  areaInteresse AreaJuridica?
  origem        OrigemCliente?
  etapa         EtapaFunil    @default(NOVO)
  temperatura   Temperatura   @default(MORNO)
  observacoes   String?
  valorEstimado Decimal?      @db.Decimal(10, 2)
  dataContato   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  escritorioId String
  escritorio   Escritorio @relation(fields: [escritorioId], references: [id])
  clienteId    String?    @unique
  cliente      Cliente?   @relation(fields: [clienteId], references: [id])

  atendimentos Atendimento[]

  @@index([escritorioId])
  @@index([escritorioId, etapa])
  @@map("leads")
}

enum EtapaFunil {
  NOVO
  PRIMEIRO_CONTATO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  CONVERTIDO
  PERDIDO
}

enum Temperatura {
  FRIO
  MORNO
  QUENTE
}

// ─── FINANCEIRO ───────────────────────────────────────────────────────────────
model Lancamento {
  id             String          @id @default(cuid())
  descricao      String
  tipo           TipoLancamento
  categoria      String?
  valor          Decimal         @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         StatusPagamento @default(PENDENTE)
  observacoes    String?
  recorrente     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  escritorioId String
  escritorio   Escritorio @relation(fields: [escritorioId], references: [id])
  clienteId    String?
  cliente      Cliente?   @relation(fields: [clienteId], references: [id])

  @@index([escritorioId])
  @@index([escritorioId, status])
  @@index([dataVencimento])
  @@map("lancamentos")
}

enum TipoLancamento {
  ENTRADA
  SAIDA
}

enum StatusPagamento {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

// ─── DOCUMENTOS ───────────────────────────────────────────────────────────────
model Documento {
  id         String   @id @default(cuid())
  nome       String
  tipo       String?
  url        String
  tamanho    Int?
  createdAt  DateTime @default(now())

  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id])
  processoId String?
  processo   Processo? @relation(fields: [processoId], references: [id])

  @@map("documentos")
}

// ─── MOVIMENTAÇÕES (DataJud) ──────────────────────────────────────────────────
model Movimentacao {
  id            String   @id @default(cuid())
  data          DateTime
  descricao     String
  tipo          String?
  fonte         String   @default("MANUAL")
  codigoExterno String?  // código do movimento no DataJud — usado para evitar duplicatas
  createdAt     DateTime @default(now())

  processoId String
  processo   Processo @relation(fields: [processoId], references: [id])

  @@index([processoId, codigoExterno])
  @@map("movimentacoes")
}

// ─── ANDAMENTOS ───────────────────────────────────────────────────────────────
model Andamento {
  id         String   @id @default(cuid())
  texto      String
  data       DateTime @default(now())
  createdAt  DateTime @default(now())

  processoId String
  processo   Processo @relation(fields: [processoId], references: [id])

  @@map("andamentos")
}

// ─── ATENDIMENTOS ─────────────────────────────────────────────────────────────
model Atendimento {
  id         String   @id @default(cuid())
  tipo       String
  descricao  String
  data       DateTime @default(now())
  createdAt  DateTime @default(now())

  clienteId String?
  cliente   Cliente?  @relation(fields: [clienteId], references: [id])
  leadId    String?
  lead      Lead?     @relation(fields: [leadId], references: [id])
  usuarioId String?
  usuario   Usuario?  @relation(fields: [usuarioId], references: [id])

  @@map("atendimentos")
}

// ─── COMENTÁRIOS ──────────────────────────────────────────────────────────────
model Comentario {
  id        String   @id @default(cuid())
  texto     String
  createdAt DateTime @default(now())

  tarefaId  String
  tarefa    Tarefa   @relation(fields: [tarefaId], references: [id])
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("comentarios")
}

// ─── ADVOGADOS MONITORADOS (DataJud) ──────────────────────────────────────────
// Para cada OAB cadastrada aqui, o cron diário consulta o DataJud em cada
// tribunal selecionado e cria Notificacao quando descobre processos novos.
model AdvogadoMonitorado {
  id                   String   @id @default(cuid())
  oab                  String   // ex: "OAB/GO 12345" ou apenas "12345"
  nome                 String?  // opcional, ajuda a filtrar resultados
  tribunais            String[] // ex: ["TJGO", "TRF1", "STJ"]
  ativo                Boolean  @default(true)
  ultimaVerificacaoAt  DateTime?
  ultimoResultadoCount Int?     // qtd de processos encontrados na última verificação
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  escritorioId String
  escritorio   Escritorio @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  usuarioId    String?    // criador (opcional)
  usuario      Usuario?   @relation(fields: [usuarioId], references: [id])

  @@unique([escritorioId, oab])
  @@index([escritorioId, ativo])
  @@map("advogados_monitorados")
}

// ─── NOTIFICAÇÕES PERSISTIDAS ─────────────────────────────────────────────────
// Notificações que precisam sobreviver entre sessões. As notificações derivadas
// (prazos próximos, tarefas vencidas) continuam sendo calculadas on-the-fly.
model Notificacao {
  id        String          @id @default(cuid())
  tipo      TipoNotificacao
  titulo    String
  descricao String?
  link      String?         // rota interna para abrir ao clicar
  metadata  Json?           // dados extras (numero CNJ, tribunal, advogadoMonitoradoId, etc)
  lida      Boolean         @default(false)
  urgente   Boolean         @default(false)
  createdAt DateTime        @default(now())
  lidaAt    DateTime?

  escritorioId String
  escritorio   Escritorio @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  usuarioId    String?    // null = visível para todos do escritório
  usuario      Usuario?   @relation(fields: [usuarioId], references: [id])

  @@index([escritorioId, lida, createdAt])
  @@index([escritorioId, usuarioId])
  @@map("notificacoes")
}

enum TipoNotificacao {
  DATAJUD_MOVIMENTACAO        // movimentação nova em processo já cadastrado
  DATAJUD_PROCESSO_DESCOBERTO // processo novo descoberto via OAB monitorada
  PRAZO_PROXIMO               // reservado p/ futuro
  TAREFA_ATRASADA             // reservado p/ futuro
}